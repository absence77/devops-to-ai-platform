# Anthropic API
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Telegram
TELEGRAM_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Kubernetes access (via JumpServer)
JUMP_SERVER=root@your-jumpserver-ip
SSH_KEY=/path/to/your/ssh/key

# Webhook security — generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
WEBHOOK_TOKEN=your_random_token_here

# ChromaDB RAG path
RAG_PATH=/path/to/your/rag/directory
